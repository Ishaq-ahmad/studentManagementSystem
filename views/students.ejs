<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student List</title>

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, Helvetica, sans-serif;
      }

      body {
        background: #f4f7fc;
        padding: 40px;
      }

      .container {
        max-width: 1100px;
        margin: auto;
      }

      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
      }

      .header h1 {
        color: #2c3e50;
        font-size: 32px;
      }

      .add-btn {
        text-decoration: none;
        background: #0d6efd;
        color: white;
        padding: 12px 22px;
        border-radius: 8px;
        font-weight: bold;
        transition: 0.3s;
      }

      .add-btn:hover {
        background: #0b5ed7;
      }

      .table-container {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.12);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead {
        background: #0d6efd;
        color: #fff;
      }

      th {
        padding: 18px;
        text-align: center;
        font-size: 16px;
        letter-spacing: 0.5px;
      }

      td {
        padding: 18px;
        text-align: center;
        color: #555;
        border-bottom: 1px solid #eee;
      }

      tbody tr:hover {
        background: #f8fbff;
      }

      tbody tr:last-child td {
        border-bottom: none;
      }

      .actions {
        display: flex;
        justify-content: center;
        gap: 10px;
      }

      .actions a {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        color: white;
        font-size: 18px;
        transition: 0.3s;
      }

      .view {
        background: #17a2b8;
      }

      .view:hover {
        background: #138496;
        transform: scale(1.1);
      }

      .edit {
        background: #ffc107;
        color: #222 !important;
      }

      .edit:hover {
        background: #e0a800;
        transform: scale(1.1);
      }

      .delete {
        background: #dc3545;
      }

      .delete:hover {
        background: #bb2d3b;
        transform: scale(1.1);
      }

      @media (max-width: 768px) {
        body {
          padding: 20px;
        }

        .table-container {
          overflow-x: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Student List</h1>

        <a href="/addStudent" class="add-btn">
          <i class="bi bi-plus-circle"></i> Add Student
        </a>
      </div>

      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Student Name</th>
              <th>Father Name</th>
              <th>Roll No</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% users.forEach((user, idx)=>{ %>
            <tr>
              <td><%= idx+1 %></td>
              <td><%= user.name %></td>
              <td><%= user.fatherName %></td>
              <td><%= user.rollNo %></td>

              <td>
                <div class="actions">
                  <a href="/viewStudent/<%=user._id%>" class="view">
                    <i class="bi bi-eye-fill"></i>
                  </a>

                  <a href="/editStudent/<%=user._id%>" class="edit">
                    <i class="bi bi-pencil-fill"></i>
                  </a>

                  <a href="/delete/<%=user._id%>" class="delete">
                    <i class="bi bi-trash-fill"></i>
                  </a>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
