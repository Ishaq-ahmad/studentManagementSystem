<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Details</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, Helvetica, sans-serif;
      }

      body {
        background: #eef3f9;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 30px;
      }

      .card {
        width: 850px;
        background: #fff;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
      }

      .header {
        background: #0d6efd;
        color: #fff;
        padding: 25px;
        text-align: center;
      }

      .header h1 {
        font-size: 30px;
      }

      .profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 30px;
      }

      .profile img {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        border: 4px solid #0d6efd;
        margin-bottom: 15px;
      }

      .profile h2 {
        color: #333;
      }

      .info {
        padding: 0 35px 35px;
      }

      .row {
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #eee;
        padding: 16px 0;
      }

      .label {
        font-weight: bold;
        color: #555;
      }

      .value {
        color: #222;
      }

      .buttons {
        display: flex;
        justify-content: center;
        gap: 20px;
        padding: 25px;
      }

      .btn {
        text-decoration: none;
        color: #fff;
        padding: 12px 30px;
        border-radius: 6px;
        font-weight: bold;
        transition: 0.3s;
      }

      .back {
        background: #6c757d;
      }

      .back:hover {
        background: #5a6268;
      }

      .edit {
        background: #198754;
      }

      .edit:hover {
        background: #157347;
      }

      @media (max-width: 700px) {
        .card {
          width: 100%;
        }

        .row {
          flex-direction: column;
          gap: 8px;
        }

        .buttons {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="header">
        <h1>Student Information</h1>
      </div>

      <div class="profile">
        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" />

        <h2><%= user.name %></h2>
      </div>

      <div class="info">
        <div class="row">
          <div class="label">Father Name</div>
          <div class="value"><%= user.fatherName%></div>
        </div>

        <div class="row">
          <div class="label">Age</div>
          <div class="value"><%= user.age %></div>
        </div>

        <div class="row">
          <div class="label">Roll Number</div>
          <div class="value"><%= user.rollNo%></div>
        </div>

        <div class="row">
          <div class="label">Email</div>
          <div class="value"><%= user.email%></div>
        </div>

        <div class="row">
          <div class="label">Phone</div>
          <div class="value"><%= user.phone%></div>
        </div>

        <div class="row">
          <div class="label">Address</div>
          <div class="value"><%= user.address%></div>
        </div>
      </div>

      <div class="buttons">
        <a href="/students" class="btn back"> ← Back </a>

        <a href="/editStudent/<%= user._id%>" class="btn edit">
          Edit Student
        </a>
      </div>
    </div>
  </body>
</html>
