<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Management System</title>
    <link rel="stylesheet" href="style.css" />

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, Helvetica, sans-serif;
      }

      body {
        background: #f4f4f4;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .container {
        width: 400px;
        background: white;
        padding: 40px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.15);
      }

      h1 {
        margin-bottom: 10px;
        color: #333;
      }

      p {
        margin-bottom: 30px;
        color: #666;
      }

      .buttons {
        display: flex;
        flex-direction: column;
        gap: 15px;
      }

      .btn {
        text-decoration: none;
        color: white;
        padding: 15px;
        border-radius: 6px;
        font-size: 18px;
        font-weight: bold;
        transition: 0.3s;
      }

      .add {
        background: #28a745;
      }

      .add:hover {
        background: #218838;
      }

      .view {
        background: #007bff;
      }

      .view:hover {
        background: #0056b3;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Student Management System</h1>
      <p>Welcome to the Student Management Dashboard</p>

      <div class="buttons">
        <a href="/addStudent" class="btn add">Add Student</a>
        <a href="/students" class="btn view">View Students</a>
      </div>
    </div>
  </body>
</html>
